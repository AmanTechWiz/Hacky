generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String                 @id @default(cuid())
  name              String?
  email             String?                @unique
  emailVerified     DateTime?
  image             String?
  githubUserId      String?                @unique
  githubUsername    String?
  avatar            String?
  createdAt         DateTime               @default(now())
  role              UserRole               @default(PARTICIPANT)
  updatedAt         DateTime               @default(now()) @updatedAt
  accounts          Account[]
  createdHackathons Hackathon[]            @relation("HackathonCreator")
  participations    HackathonParticipant[]
  judgeAssignments  HackathonJudge[]
  sessions          Session[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Hackathon {
  id                 String                 @id @default(cuid())
  title              String
  slug               String                 @unique
  description        String?
  startAt            DateTime
  endAt              DateTime
  registrationCloses DateTime
  inviteCode         String?                @unique
  status             HackathonStatus        @default(PUBLISHED)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  createdById        String
  createdBy          User                   @relation("HackathonCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants       HackathonParticipant[]
  judges             HackathonJudge[]
}

model HackathonParticipant {
  id                 String       @id @default(cuid())
  userId             String
  hackathonId        String
  joinedAt           DateTime     @default(now())
  teamName           String       @default("Team Name")
  teamLeader         String       @default("Team Leader")
  teammateGithubUrls String[]     @default([])
  memberCount        Int          @default(1)
  trackedRepo        String       @default("https://github.com/owner/repo")
  deployedUrl        String?
  presentationLink   String?
  hackathon          Hackathon    @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluations        Evaluation[]

  @@unique([userId, hackathonId])
  @@index([hackathonId])
}

model HackathonJudge {
  id          String       @id @default(cuid())
  userId      String
  hackathonId String
  invitedAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  hackathon   Hackathon    @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  evaluations Evaluation[]

  @@unique([userId, hackathonId])
  @@index([hackathonId])
}

model Evaluation {
  id            String               @id @default(cuid())
  judgeId       String
  participantId String
  innovation    Int
  presentation  Int
  feedback      String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  judge         HackathonJudge       @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  participant   HackathonParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([judgeId, participantId])
}

enum UserRole {
  PARTICIPANT
  ORGANIZER
  JUDGE
}

enum HackathonStatus {
  DRAFT
  PUBLISHED
  COMPLETED
}
